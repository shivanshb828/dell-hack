# Twilio
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_PHONE_NUMBER_SID=
PUBLIC_URL=https://your-ngrok.ngrok-free.app

# Gemini Live
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Aoede

# VAD tuning (Gemini Live built-in)
GEMINI_VAD_START_SENSITIVITY=START_SENSITIVITY_LOW
GEMINI_VAD_END_SENSITIVITY=END_SENSITIVITY_LOW
GEMINI_VAD_PREFIX_PADDING_MS=20
GEMINI_VAD_SILENCE_DURATION_MS=300

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*
DISABLE_TWILIO_SIGNATURE_VALIDATION=true

# Firm branding
FIRM_NAME=Donna & Associates
AGENT_NAME=Donna
ATTORNEY_EMAIL=attorney@example.com
ATTORNEY_NAME=Counselor
# Attorney's personal cell — calls from this number unlock the portal mode
ATTORNEY_PHONE=+19259676242
TWILIO_TRANSFER_NUMBER=

# Donna bridges
DONNA_DB_PATH=./voice_agent.sqlite
DONNA_DRAFTS_DIR=./drafts
DONNA_EMAIL_SERVER_URL=

# Internal API auth — shared secret for POST /api/calls/outbound
DONNA_API_KEY=

# Voice provider routing
VOICE_PROVIDER=gemini
